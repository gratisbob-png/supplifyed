# SUPPLIFYED — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in all values
# Never commit .env.local to git

# ─── SURREALDB ────────────────────────────────────────
SURREALDB_URL=http://localhost:8000
SURREALDB_NS=supplifyed
SURREALDB_DB=production
SURREALDB_USER=root
SURREALDB_PASS=

# ─── AMAZON ───────────────────────────────────────────
# Amazon Associates Partner Tag (from Associates Central)
AMAZON_PARTNER_TAG=

# Amazon Product Advertising API (separate application)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_HOST=webservices.amazon.co.uk
AMAZON_REGION=eu-west-1

# ─── AFFILIATE NETWORKS ───────────────────────────────
AWIN_PUBLISHER_ID=
CJ_WEBSITE_ID=
SHAREASALE_MERCHANT_ID=

# ─── ANALYTICS ────────────────────────────────────────
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# ─── APP CONFIG ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://supplifyed.com

# Brand marketing content cap (characters) — NEXT_PUBLIC_ prefix required for client components
NEXT_PUBLIC_BRAND_MARKETING_CHAR_LIMIT=500

# Link check interval (days)
LINK_CHECK_INTERVAL_DAYS=7

# ─── REQUIRED BEFORE LAUNCH ───────────────────────────
# All values above must be populated before going live.
# The system will not start without:
#   SURREALDB_URL, SURREALDB_USER, SURREALDB_PASS
#   AMAZON_PARTNER_TAG
#   NEXT_PUBLIC_SITE_URL
